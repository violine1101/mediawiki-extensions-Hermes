{
	"name": "Hermes",
	"author": [
		"violine1101"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:Hermes",
	"descriptionmsg": "hermes-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.45.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Hermes\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\Hermes\\Tests\\": "tests/phpunit/integration/"
	},
	"config": {
		"HermesDebug": {
			"description": "Enable Hermes debug features.",
			"value": false
		},
		"HermesWikis": {
			"description": "Map of wiki ID => URL template (with \"$1\" as the page title placeholder) for every wiki in the Hermes deployment.",
			"value": {}
		},
		"HermesWarnings": {
			"description": "Show on-page warning boxes for non-fatal issues resulting from the extension, such as Hermes tag ambiguities, conflicts, or duplicate {{#hermes:}} calls. When disabled, the relevant tracking categories are still applied, but no on-page warnings are shown.",
			"value": true
		}
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "init",
		"UnitTestsAfterDatabaseSetup": "init",
		"BeforeInitialize": "init",
		"LinksUpdateComplete": "parserfunc",
		"PageDeleteComplete": "parserfunc",
		"ParserFirstCallInit": "parserfunc",
		"LanguageLinks": "languagelinks",
		"MediaWikiServices": "languagelinks",
		"getUserPermissionsErrors": "translationproject",
		"PageContentLanguage": "translationproject",
		"UserGetLanguageObject": "translationproject",
		"ParserAfterParse": [ "parserfunc", "translationproject" ],
		"OutputPageBeforeHTML": "translationproject"
	},
	"HookHandlers": {
		"init": {
			"class": "MediaWiki\\Extension\\Hermes\\Hooks\\InitHooks"
		},
		"parserfunc": {
			"class": "MediaWiki\\Extension\\Hermes\\Hooks\\ParserFuncHooks"
		},
		"languagelinks": {
			"class": "MediaWiki\\Extension\\Hermes\\Hooks\\LanguageLinkHooks"
		},
		"translationproject": {
			"class": "MediaWiki\\Extension\\Hermes\\Hooks\\TranslationProjectHooks"
		}
	},
	"ExtensionMessagesFiles": {
		"HermesMagic": "Hermes.magic.php"
	},
	"MessagesDirs": {
		"Hermes": [
			"i18n"
		]
	},
	"DatabaseVirtualDomains": [
		"virtual-hermes"
	],
	"TrackingCategories": [
		"hermes-duplicate-call-category",
		"hermes-tag-conflict-category",
		"hermes-ambiguous-links-category"
	],
	"ResourceModules": {
		"ext.hermes": {
			"localBasePath": "resources/ext.hermes",
			"remoteExtPath": "Hermes/resources/ext.hermes",
			"dependencies": [],
			"styles": [],
			"packageFiles": [
				"init.js"
			],
			"messages": []
		}
	},
	"manifest_version": 2
}
