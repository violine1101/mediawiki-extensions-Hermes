{
	"name": "Hermes",
	"author": [
		"violine1101"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:Hermes",
	"descriptionmsg": "hermes-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.45.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Hermes\\": "src/"
	},
	"config": {
		"HermesEnableFoo": {
			"description": "Enable the Foo feature.",
			"value": true
		},
		"VandalizeEachPage": {
			"description": "Write 'Hermes was here' on each page",
			"value": false
		}
	},
	"Hooks": {
		"BeforePageDisplay": "main",
		"LinksUpdateComplete": "main",
		"LoadExtensionSchemaUpdates": "main",
		"PageDeleteComplete": "main",
		"ParserFirstCallInit": "main"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\Hermes\\Hooks"
		}
	},
	"ExtensionMessagesFiles": {
		"HermesMagic": "Hermes.magic.php"
	},
	"MessagesDirs": {
		"Hermes": [
			"i18n"
		]
	},
	"DatabaseVirtualDomains": [
		"virtual-hermes"
	],
	"ResourceModules": {
		"ext.hermes": {
			"localBasePath": "resources/ext.hermes",
			"remoteExtPath": "Hermes/resources/ext.hermes",
			"dependencies": [],
			"styles": [],
			"packageFiles": [
				"init.js"
			],
			"messages": []
		}
	},
	"manifest_version": 2
}
